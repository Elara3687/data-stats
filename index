<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📊 作品数据统计助手</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: #f5f7fa;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .container {
            max-width: 1400px;
            width: 100%;
            background: white;
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            padding: 32px;
        }
        h1 {
            font-size: 28px;
            font-weight: 600;
            color: #1a1a2e;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .subtitle {
            color: #666;
            margin-bottom: 28px;
            font-size: 15px;
            border-left: 4px solid #4f46e5;
            padding-left: 16px;
        }
        .upload-section {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .upload-area {
            flex: 1;
            min-width: 280px;
            border: 2px dashed #d1d5db;
            border-radius: 20px;
            padding: 32px 24px;
            text-align: center;
            background: #fafbfc;
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .upload-area.config-area {
            border-color: #c7d2fe;
            background: #f8f7ff;
        }
        .upload-area:hover {
            border-color: #4f46e5;
            background: #f8f7ff;
        }
        .upload-area.dragover {
            border-color: #4f46e5;
            background: #eef2ff;
        }
        .upload-icon { font-size: 40px; margin-bottom: 12px; }
        .upload-text { font-size: 16px; font-weight: 500; color: #1f2937; margin-bottom: 6px; }
        .upload-hint { color: #6b7280; font-size: 13px; }
        .config-status {
            display: inline-block;
            margin-top: 8px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            background: #e0e7ff;
            color: #3730a3;
        }
        #fileInfo, #configFileInfo {
            margin-bottom: 16px;
            padding: 10px 16px;
            background: #ecfdf5;
            border-radius: 10px;
            color: #065f46;
            font-size: 13px;
            display: none;
        }
        #configFileInfo {
            background: #eef2ff;
            color: #3730a3;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 14px;
            margin-bottom: 28px;
        }
        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 18px 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            border: 1px solid #f0f0f0;
        }
        .stat-label { font-size: 13px; color: #6b7280; margin-bottom: 8px; }
        .stat-value { font-size: 32px; font-weight: 700; color: #1a1a2e; }
        .stat-unit { font-size: 13px; font-weight: 400; color: #9ca3af; margin-left: 4px; }
        .summary-box {
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            border-radius: 16px;
            padding: 18px 24px;
            margin: 24px 0 20px 0;
            border-left: 6px solid #4f46e5;
            font-size: 15px;
            line-height: 1.6;
            color: #1a1a2e;
            font-weight: 500;
        }
        .section-title {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a2e;
            margin: 24px 0 16px 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .table-wrapper {
            overflow-x: auto;
            border-radius: 16px;
            border: 1px solid #edf2f7;
            margin-bottom: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            min-width: 600px;
        }
        th {
            background: #f8fafc;
            padding: 12px 14px;
            text-align: left;
            font-weight: 600;
            color: #334155;
            border-bottom: 1px solid #e2e8f0;
            white-space: nowrap;
        }
        td {
            padding: 10px 14px;
            border-bottom: 1px solid #f1f5f9;
            color: #1e293b;
        }
        tr:last-child td { border-bottom: none; }
        .export-btn {
            background: #4f46e5;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            margin-top: 12px;
            margin-right: 12px;
        }
        .export-btn.secondary {
            background: white;
            color: #4f46e5;
            border: 1px solid #4f46e5;
        }
        .export-btn.secondary:hover {
            background: #f0f4ff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.1);
        }
        .export-btn:hover {
            background: #4338ca;
            transform: translateY(-1px);
            box-shadow: 0 8px 16px rgba(79, 70, 229, 0.2);
        }
        .empty-state { text-align: center; padding: 40px; color: #9ca3af; }
        .btn-group { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 12px; }
        .unmatched-badge {
            background: #fef3c7;
            color: #92400e;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            margin-left: 8px;
        }
    </style>
</head>
<body>
<div class="container">
    <h1><span>📋 作品数据统计助手</span></h1>
    <div class="subtitle">上传后台导出的表格 · 自动统计评级、状态、创作者明细</div>

    <div class="upload-section">
        <div class="upload-area" id="uploadArea">
            <div class="upload-icon">📂</div>
            <div class="upload-text">上传作品数据表</div>
            <div class="upload-hint">支持 .xlsx, .xls, .csv 格式</div>
            <input type="file" id="fileInput" accept=".xlsx,.xls,.csv" style="display: none;">
        </div>
        <div class="upload-area config-area" id="configUploadArea">
            <div class="upload-icon">👤</div>
            <div class="upload-text">上传负责人配置表</div>
            <div class="upload-hint">包含「用户昵称」和「负责人」两列</div>
            <span class="config-status" id="configStatus">未加载配置</span>
            <input type="file" id="configFileInput" accept=".xlsx,.xls,.csv" style="display: none;">
        </div>
    </div>

    <div id="fileInfo"></div>
    <div id="configFileInfo"></div>

    <div id="statsContainer" style="display: none;">
        <div class="stats-grid" id="statsCards"></div>

        <div class="summary-box" id="summaryBox"></div>

        <div class="section-title">
            <span>👤 创作者评级汇总</span>
            <span style="font-size: 14px; font-weight: 400; color: #6b7280;" id="creatorCount"></span>
        </div>
        <div class="table-wrapper">
            <table id="creatorTable">
                <thead>
                    <tr>
                        <th>用户昵称</th>
                        <th>用户UID</th>
                        <th>总作品数</th>
                        <th>S+</th>
                        <th>S</th>
                        <th>A+</th>
                        <th>A</th>
                        <th>B&B+</th>
                        <th>S率</th>
                    </tr>
                </thead>
                <tbody id="creatorTableBody"></tbody>
            </table>
        </div>

        <div class="section-title">
            <span>🧑‍💼 负责人维度分析</span>
            <span style="font-size: 14px; font-weight: 400; color: #6b7280;" id="managerCount"></span>
        </div>
        <div class="table-wrapper">
            <table id="managerTable">
                <thead id="managerTableHead">
                </thead>
                <tbody id="managerTableBody">
                </tbody>
            </table>
        </div>

        <div class="btn-group">
            <button class="export-btn" id="exportSummaryBtn">
                ⬇️ 导出汇总表
            </button>
            <button class="export-btn secondary" id="exportDetailMultiBtn">
                📚 导出明细表（每人一个Sheet）
            </button>
            <button class="export-btn secondary" id="exportFullBtn">
                📦 导出总表
            </button>
            <button class="export-btn" id="exportManagerBtn">
                🧑‍💼 导出负责人表
            </button>
        </div>
    </div>
</div>

<script>
(function(){
    "use strict";

    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('fileInput');
    const configUploadArea = document.getElementById('configUploadArea');
    const configFileInput = document.getElementById('configFileInput');
    const fileInfo = document.getElementById('fileInfo');
    const configFileInfo = document.getElementById('configFileInfo');
    const configStatus = document.getElementById('configStatus');
    const statsContainer = document.getElementById('statsContainer');
    const statsCards = document.getElementById('statsCards');
    const summaryBox = document.getElementById('summaryBox');
    const creatorTableBody = document.getElementById('creatorTableBody');
    const creatorCountSpan = document.getElementById('creatorCount');
    const managerTableHead = document.getElementById('managerTableHead');
    const managerTableBody = document.getElementById('managerTableBody');
    const managerCountSpan = document.getElementById('managerCount');
    const exportSummaryBtn = document.getElementById('exportSummaryBtn');
    const exportDetailMultiBtn = document.getElementById('exportDetailMultiBtn');
    const exportFullBtn = document.getElementById('exportFullBtn');
    const exportManagerBtn = document.getElementById('exportManagerBtn');

    let parsedData = [];
    let statistics = null;
    let rawRows = [];
    let headers = [];
    let colMap = {};
    let managerMap = new Map();
    let allDates = [];

    function formatDate(date) {
        const d = new Date(date);
        return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    }

    function formatDateShort(dateStr) {
        const parts = dateStr.split('-');
        if (parts.length === 3) {
            return `${parseInt(parts[1])}/${parseInt(parts[2])}`;
        }
        return dateStr;
    }

    function normalizeRating(rating) {
        if (!rating) return null;
        const r = String(rating).trim().toUpperCase();
        if (r === 'S+') return 'S+';
        if (r === 'S') return 'S';
        if (r === 'A+') return 'A+';
        if (r === 'A') return 'A';
        if (r === 'B' || r === 'B+') return 'B&B+';
        return r;
    }

    function parseExcelDate(value) {
        if (!value) return null;
        if (typeof value === 'number') {
            const date = XLSX.SSF.parse_date_code(value);
            return new Date(date.y, date.m - 1, date.d);
        }
        const str = String(value).trim();
        if (str.includes('/') || str.includes('-')) {
            return new Date(str);
        }
        return null;
    }

    // 解析负责人配置表（用昵称匹配）
    function parseConfigFile(file) {
        const reader = new FileReader();
        reader.onload = (e) => {
            const data = new Uint8Array(e.target.result);
            const workbook = XLSX.read(data, { type: 'array' });
            const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
            const rows = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });
            
            if (rows.length < 2) {
                alert('配置表至少需要包含表头和一行数据');
                return;
            }

            const headers = rows[0];
            let nameCol = -1, managerCol = -1;

            headers.forEach((h, idx) => {
                const str = String(h || '').trim();
                if (str.includes('昵称') || str === '用户昵称' || str === '昵称') nameCol = idx;
                if (str.includes('负责人')) managerCol = idx;
            });

            if (nameCol === -1 || managerCol === -1) {
                alert('配置表需要包含「用户昵称」和「负责人」两列');
                return;
            }

            managerMap.clear();
            for (let i = 1; i < rows.length; i++) {
                const row = rows[i];
                if (!row || row.every(cell => !cell)) continue;
                const nickname = String(row[nameCol] || '').trim();
                const manager = String(row[managerCol] || '').trim();
                if (nickname && manager) {
                    managerMap.set(nickname, manager);
                }
            }

            configStatus.textContent = `已加载 ${managerMap.size} 条配置`;
            configStatus.style.background = '#d1fae5';
            configStatus.style.color = '#065f46';
            configFileInfo.style.display = 'block';
            configFileInfo.innerHTML = `✅ 已加载负责人配置：${file.name} · 共 ${managerMap.size} 条（通过昵称匹配）`;

            if (parsedData.length > 0) {
                calculateStats();
                renderUI();
            }
        };
        reader.readAsArrayBuffer(file);
    }

    function findManager(nickname) {
        if (managerMap.has(nickname)) return managerMap.get(nickname);
        const trimmed = nickname.trim();
        if (managerMap.has(trimmed)) return managerMap.get(trimmed);
        for (const [key, val] of managerMap) {
            if (key.toLowerCase() === nickname.toLowerCase()) return val;
        }
        return null;
    }

    // 解析作品数据表
    function parseFile(file) {
        const reader = new FileReader();
        reader.onload = (e) => {
            const data = new Uint8Array(e.target.result);
            const workbook = XLSX.read(data, { type: 'array' });
            const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
            const rows = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });
            
            if (rows.length < 2) {
                alert('表格至少需要包含表头和一行数据');
                return;
            }

            rawRows = rows;
            headers = rows[0];
            
            colMap = {
                publishDate: -1, offlineStatus: -1, rating: -1, nickname: -1, uid: -1, tags: -1,
                workId: -1, shareLink: -1, title: -1, taskCount: -1, viewCount: -1,
                likeCount: -1, commentCount: -1, remixCount: -1
            };

            headers.forEach((h, idx) => {
                const headerStr = String(h || '').trim();
                if (headerStr === '作品发布日期') colMap.publishDate = idx;
                else if (headerStr === '下架状态') colMap.offlineStatus = idx;
                else if (headerStr === '作品评级') colMap.rating = idx;
                else if (headerStr === '用户昵称') colMap.nickname = idx;
                else if (headerStr === '用户 UID') colMap.uid = idx;
                else if (headerStr === '标签') colMap.tags = idx;
                else if (headerStr === '作品 ID') colMap.workId = idx;
                else if (headerStr === '分享链接') colMap.shareLink = idx;
                else if (headerStr === '作品标题') colMap.title = idx;
                else if (headerStr === '任务数') colMap.taskCount = idx;
                else if (headerStr === '浏览量') colMap.viewCount = idx;
                else if (headerStr === '点赞数') colMap.likeCount = idx;
                else if (headerStr === '评论数') colMap.commentCount = idx;
                else if (headerStr === 'Remix数') colMap.remixCount = idx;
            });

            const records = [];
            const dateSet = new Set();
            
            for (let i = 1; i < rows.length; i++) {
                const row = rows[i];
                if (!row || row.every(cell => !cell)) continue;

                const pubDateRaw = colMap.publishDate >= 0 ? row[colMap.publishDate] : null;
                const offlineStatus = colMap.offlineStatus >= 0 ? String(row[colMap.offlineStatus] || '').trim() : '';
                const ratingRaw = colMap.rating >= 0 ? row[colMap.rating] : null;
                const nickname = colMap.nickname >= 0 ? String(row[colMap.nickname] || '未知用户').trim() : '未知用户';
                const uid = colMap.uid >= 0 ? String(row[colMap.uid] || '').trim() : '';
                const tags = colMap.tags >= 0 ? String(row[colMap.tags] || '').trim() : '';

                const pubDate = parseExcelDate(pubDateRaw);
                const pubDateStr = pubDate ? formatDate(pubDate) : '';
                
                if (pubDateStr) dateSet.add(pubDateStr);

                records.push({
                    rowIndex: i,
                    publishDate: pubDate,
                    publishDateStr: pubDateStr,
                    offlineStatus: offlineStatus,
                    rating: ratingRaw,
                    nickname: nickname,
                    uid: uid,
                    tags: tags
                });
            }

            allDates = Array.from(dateSet).sort();
            
            parsedData = records;
            fileInfo.style.display = 'block';
            fileInfo.innerHTML = `✅ 已加载文件：${file.name} · 共 ${records.length} 条记录`;
            
            calculateStats();
            renderUI();
        };
        reader.readAsArrayBuffer(file);
    }

    function calculateStats() {
        const validDates = parsedData.filter(r => r.publishDate).map(r => r.publishDate);
        let minDate = validDates.length > 0 ? new Date(Math.min(...validDates)) : new Date();
        let maxDate = validDates.length > 0 ? new Date(Math.max(...validDates)) : new Date();

        const rangeStartStr = formatDate(minDate);
        const rangeEndStr = formatDate(maxDate);

        parsedData.forEach(r => {
            const normRating = normalizeRating(r.rating);
            r.isSWork = (normRating === 'S+' || normRating === 'S');
        });

        const rangePublished = parsedData.filter(r => r.publishDate);
        const published = parsedData.filter(r => r.offlineStatus === '已发布');
        const offline = parsedData.filter(r => r.offlineStatus === '已下架');
        const unrated = parsedData.filter(r => {
            const rating = r.rating;
            return rating === null || rating === undefined || String(rating).trim() === '';
        });
        const pendingModify = parsedData.filter(r => r.tags.includes('待修改'));
        const cannotPlay = parsedData.filter(r => r.tags.includes('玩不了'));

        const ratedWorks = parsedData.filter(r => {
            const rating = r.rating;
            return rating !== null && rating !== undefined && String(rating).trim() !== '';
        });

        const ratingCount = { 'S+': 0, 'S': 0, 'A+': 0, 'A': 0, 'B&B+': 0 };
        ratedWorks.forEach(r => {
            const norm = normalizeRating(r.rating);
            if (ratingCount.hasOwnProperty(norm)) ratingCount[norm]++;
        });

        const totalRated = ratedWorks.length;
        const sPlusAndS = (ratingCount['S+'] || 0) + (ratingCount['S'] || 0);
        const sRate = totalRated > 0 ? ((sPlusAndS / totalRated) * 100).toFixed(2) : '0.00';

        // 按创作者统计
        const creatorMap = new Map();
        const creatorOrder = [];
        parsedData.forEach(rec => {
            const key = rec.uid + '__' + rec.nickname;
            if (!creatorMap.has(key)) {
                creatorMap.set(key, {
                    uid: rec.uid,
                    nickname: rec.nickname,
                    total: 0,
                    weekTotal: 0,
                    weekSCount: 0,
                    'S+': 0, 'S': 0, 'A+': 0, 'A': 0, 'B&B+': 0
                });
                creatorOrder.push(key);
            }
            const creator = creatorMap.get(key);
            creator.total++;
            if (rec.isSWork && rec.publishDate) {
                creator.weekTotal++;
                creator.weekSCount++;
            } else if (rec.publishDate) {
                creator.weekTotal++;
            }
            const norm = normalizeRating(rec.rating);
            if (creator.hasOwnProperty(norm)) creator[norm]++;
        });

        const creators = creatorOrder.map(key => {
            const c = creatorMap.get(key);
            const ratedTotal = c['S+'] + c['S'] + c['A+'] + c['A'] + c['B&B+'];
            const sCount = (c['S+'] || 0) + (c['S'] || 0);
            const sRateCreator = ratedTotal > 0 ? ((sCount / ratedTotal) * 100).toFixed(2) : '0.00';
            const weekSRate = c.weekTotal > 0 ? ((c.weekSCount / c.weekTotal) * 100).toFixed(2) : '0.00';
            return { ...c, ratedTotal, sRate: sRateCreator, weekSRate };
        });

        // 按负责人统计
        const managerStats = new Map();
        
        parsedData.forEach(rec => {
            const manager = findManager(rec.nickname) || '未分配';
            const dateStr = rec.publishDateStr;
            
            if (!managerStats.has(manager)) {
                managerStats.set(manager, { total: 0, daily: new Map() });
            }
            const ms = managerStats.get(manager);
            ms.total++;
            if (dateStr) {
                ms.daily.set(dateStr, (ms.daily.get(dateStr) || 0) + 1);
            }
        });

        const managers = Array.from(managerStats.entries()).map(([name, data]) => {
            return { name, total: data.total, daily: data.daily };
        }).sort((a, b) => b.total - a.total);

        const monthDayFormat = (dateStr) => {
            const parts = dateStr.split('-');
            if (parts.length === 3) {
                return `${parseInt(parts[1])}月${parseInt(parts[2])}日`;
            }
            return dateStr;
        };

        statistics = {
            rangeStart: rangeStartStr,
            rangeEnd: rangeEndStr,
            rangeStartShort: monthDayFormat(rangeStartStr),
            rangeEndShort: monthDayFormat(rangeEndStr),
            rangePublishedCount: rangePublished.length,
            publishedCount: published.length,
            offlineCount: offline.length,
            unratedCount: unrated.length,
            pendingModifyCount: pendingModify.length,
            cannotPlayCount: cannotPlay.length,
            ratingCount,
            totalRated,
            sRate,
            creators,
            managers,
            allDates,
            summaryText: `从${monthDayFormat(rangeStartStr)}至${monthDayFormat(rangeEndStr)} 已发布${published.length}条，未评级${unrated.length}条，待修改和玩不了${pendingModify.length + cannotPlay.length}条；S+ ${ratingCount['S+']}条，S ${ratingCount['S']}条，A+ ${ratingCount['A+']}条，A ${ratingCount['A']}条，B&B+ ${ratingCount['B&B+']}条；S率约为${sRate}%`
        };
    }

    function renderUI() {
        if (!statistics) return;
        statsContainer.style.display = 'block';

        const s = statistics;

        const cardsHtml = `
            <div class="stat-card"><div class="stat-label">📅 发布区间 (${s.rangeStart} ~ ${s.rangeEnd})</div><div class="stat-value">${s.rangePublishedCount}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">✅ 已发布</div><div class="stat-value">${s.publishedCount}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">📦 已下架</div><div class="stat-value">${s.offlineCount}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">❓ 未评级</div><div class="stat-value">${s.unratedCount}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">✏️ 待修改</div><div class="stat-value">${s.pendingModifyCount}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">🚫 玩不了</div><div class="stat-value">${s.cannotPlayCount}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">🏆 S+</div><div class="stat-value">${s.ratingCount['S+']}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">🌟 S</div><div class="stat-value">${s.ratingCount['S']}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">📈 A+</div><div class="stat-value">${s.ratingCount['A+']}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">📊 A</div><div class="stat-value">${s.ratingCount['A']}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">📋 B&B+</div><div class="stat-value">${s.ratingCount['B&B+']}<span class="stat-unit">条</span></div></div>
            <div class="stat-card"><div class="stat-label">📐 S率</div><div class="stat-value">${s.sRate}<span class="stat-unit">%</span></div></div>
        `;
        statsCards.innerHTML = cardsHtml;
        summaryBox.textContent = s.summaryText;

        if (s.creators.length === 0) {
            creatorTableBody.innerHTML = `<tr><td colspan="9" class="empty-state">暂无创作者数据</td></tr>`;
            creatorCountSpan.textContent = '';
        } else {
            let rowsHtml = '';
            s.creators.forEach(c => {
                rowsHtml += `<tr><td>${c.nickname}</td><td>${c.uid}</td><td>${c.total}</td><td>${c['S+']}</td><td>${c['S']}</td><td>${c['A+']}</td><td>${c['A']}</td><td>${c['B&B+']}</td><td>${c.sRate}%</td></tr>`;
            });
            creatorTableBody.innerHTML = rowsHtml;
            creatorCountSpan.textContent = `共 ${s.creators.length} 位创作者`;
        }

        renderManagerTable();
    }

    function renderManagerTable() {
        const s = statistics;
        const dates = s.allDates;
        
        let headHtml = '<tr><th>负责人</th><th>总数</th>';
        dates.forEach(d => {
            headHtml += `<th>${formatDateShort(d)}</th>`;
        });
        headHtml += '</tr>';
        managerTableHead.innerHTML = headHtml;

        if (s.managers.length === 0) {
            managerTableBody.innerHTML = `<tr><td colspan="${dates.length + 2}" class="empty-state">暂无负责人数据，请先上传配置表</td></tr>`;
            managerCountSpan.textContent = '';
            return;
        }

        let bodyHtml = '';
        s.managers.forEach(m => {
            bodyHtml += '<tr>';
            bodyHtml += `<td>${m.name}${m.name === '未分配' ? '<span class="unmatched-badge">未匹配</span>' : ''}</td>`;
            bodyHtml += `<td>${m.total}</td>`;
            dates.forEach(d => {
                bodyHtml += `<td>${m.daily.get(d) || 0}</td>`;
            });
            bodyHtml += '</tr>';
        });
        managerTableBody.innerHTML = bodyHtml;
        managerCountSpan.textContent = `共 ${s.managers.length} 位负责人`;
    }

    function getCellValue(row, colIndex) {
        if (colIndex < 0 || !row) return '';
        const val = row[colIndex];
        return val !== undefined && val !== null ? val : '';
    }

    // ========== 导出功能 ==========
    function exportSummary() {
        if (!statistics) return;
        const s = statistics;
        const exportRows = [['用户昵称', '用户UID', '总作品数', 'S+', 'S', 'A+', 'A', 'B&B+', 'S率']];
        s.creators.forEach(c => {
            exportRows.push([c.nickname, c.uid, c.total, c['S+'], c['S'], c['A+'], c['A'], c['B&B+'], c.sRate + '%']);
        });
        const ws = XLSX.utils.aoa_to_sheet(exportRows);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, '创作者汇总');
        XLSX.writeFile(wb, `创作者汇总_${s.rangeEnd}.xlsx`);
    }

    function exportDetailMulti() {
        if (!statistics || rawRows.length === 0) return;
        const s = statistics;
        const wb = XLSX.utils.book_new();

        const groupedByCreator = new Map();
        parsedData.forEach(rec => {
            const key = rec.uid + '__' + rec.nickname;
            if (!groupedByCreator.has(key)) groupedByCreator.set(key, []);
            groupedByCreator.get(key).push(rec);
        });

        s.creators.forEach(c => {
            const key = c.uid + '__' + c.nickname;
            const records = groupedByCreator.get(key) || [];
            
            const detailRows = [];
            detailRows.push(['作品发布日期', '作品 ID', '分享链接', '作品标题', '下架状态', '作品评级', '任务数', '浏览量', '点赞数', '评论数', 'Remix数', '本周S作品数', '本周S率', '总作品数']);
            
            records.forEach((rec, index) => {
                const row = rawRows[rec.rowIndex];
                const baseData = [
                    rec.publishDateStr,
                    getCellValue(row, colMap.workId),
                    getCellValue(row, colMap.shareLink),
                    getCellValue(row, colMap.title),
                    rec.offlineStatus,
                    rec.rating || '',
                    getCellValue(row, colMap.taskCount),
                    getCellValue(row, colMap.viewCount),
                    getCellValue(row, colMap.likeCount),
                    getCellValue(row, colMap.commentCount),
                    getCellValue(row, colMap.remixCount)
                ];
                if (index === 0) {
                    detailRows.push([...baseData, c.weekSCount, c.weekSRate + '%', c.total]);
                } else {
                    detailRows.push([...baseData, '', '', '']);
                }
            });

            let sheetName = c.nickname.replace(/[\\\/\?\*\[\]:]/g, '').substring(0, 31);
            if (!sheetName) sheetName = c.uid.substring(0, 31);
            
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(detailRows), sheetName);
        });

        XLSX.writeFile(wb, `创作者明细_分Sheet_${s.rangeEnd}.xlsx`);
    }

    function exportFull() {
        if (!statistics || rawRows.length === 0) return;
        const s = statistics;
        const wb = XLSX.utils.book_new();

        XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rawRows), '原始数据');

        const summaryRows = [['用户昵称', '总作品数', '本周S率']];
        s.creators.forEach(c => summaryRows.push([c.nickname, c.total, c.weekSRate + '%']));
        XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(summaryRows), '人员汇总');

        const groupedByCreator = new Map();
        parsedData.forEach(rec => {
            const key = rec.uid + '__' + rec.nickname;
            if (!groupedByCreator.has(key)) groupedByCreator.set(key, []);
            groupedByCreator.get(key).push(rec);
        });

        s.creators.forEach(c => {
            const records = groupedByCreator.get(c.uid + '__' + c.nickname) || [];
            const detailRows = [];
            detailRows.push(['作品发布日期', '作品 ID', '分享链接', '作品标题', '下架状态', '作品评级', '任务数', '浏览量', '点赞数', '评论数', 'Remix数', '本周S作品数', '本周S率', '总作品数']);
            
            records.forEach((rec, index) => {
                const row = rawRows[rec.rowIndex];
                const baseData = [
                    rec.publishDateStr,
                    getCellValue(row, colMap.workId),
                    getCellValue(row, colMap.shareLink),
                    getCellValue(row, colMap.title),
                    rec.offlineStatus,
                    rec.rating || '',
                    getCellValue(row, colMap.taskCount),
                    getCellValue(row, colMap.viewCount),
                    getCellValue(row, colMap.likeCount),
                    getCellValue(row, colMap.commentCount),
                    getCellValue(row, colMap.remixCount)
                ];
                detailRows.push(index === 0 ? [...baseData, c.weekSCount, c.weekSRate + '%', c.total] : [...baseData, '', '', '']);
            });

            let sheetName = c.nickname.replace(/[\\\/\?\*\[\]:]/g, '').substring(0, 31) || c.uid.substring(0, 31);
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(detailRows), sheetName);
        });

        XLSX.writeFile(wb, `总表_${s.rangeEnd}.xlsx`);
    }

    function exportManager() {
        if (!statistics) return;
        const s = statistics;
        const dates = s.allDates;
        
        const exportRows = [];
        const headerRow = ['负责人', '总审核量'];
        dates.forEach(d => headerRow.push(formatDateShort(d)));
        exportRows.push(headerRow);
        
        s.managers.forEach(m => {
            const row = [m.name, m.total];
            dates.forEach(d => row.push(m.daily.get(d) || 0));
            exportRows.push(row);
        });
        
        const ws = XLSX.utils.aoa_to_sheet(exportRows);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, '负责人维度分析');
        XLSX.writeFile(wb, `负责人分析_${s.rangeEnd}.xlsx`);
    }

    // ========== 事件绑定 ==========
    uploadArea.addEventListener('click', () => fileInput.click());
    uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); uploadArea.classList.add('dragover'); });
    uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
    uploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadArea.classList.remove('dragover');
        const file = e.dataTransfer.files[0];
        if (file) parseFile(file);
    });
    fileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) parseFile(file);
        fileInput.value = '';
    });

    configUploadArea.addEventListener('click', () => configFileInput.click());
    configUploadArea.addEventListener('dragover', (e) => { e.preventDefault(); configUploadArea.classList.add('dragover'); });
    configUploadArea.addEventListener('dragleave', () => configUploadArea.classList.remove('dragover'));
    configUploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        configUploadArea.classList.remove('dragover');
        const file = e.dataTransfer.files[0];
        if (file) parseConfigFile(file);
    });
    configFileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) parseConfigFile(file);
        configFileInput.value = '';
    });

    exportSummaryBtn.addEventListener('click', exportSummary);
    exportDetailMultiBtn.addEventListener('click', exportDetailMulti);
    exportFullBtn.addEventListener('click', exportFull);
    exportManagerBtn.addEventListener('click', exportManager);

    statsContainer.style.display = 'none';
})();
</script>
</body>
</html>
